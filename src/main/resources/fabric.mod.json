{
	"schemaVersion": 1,
	"id": "winterssummerfixes",
	"version": "${version}",
	"name": "Winter's Summer Fixes",
	"description": "Some fixes done for the Winter's Summer modpack.",
	"authors": [
		"devOS: Sanity Edition",
		"Team Nautical"
	],
	"contributors": [
		"asojidev"
	],
	"contact": {
		"homepage": "https://devos.one/",
		"sources": "https://github.com/devOS-Sanity-Edition/winters-summer-fixes"
	},
	"license": "MIT",
	"icon": "assets/winterssummerfixes/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"adapter": "kotlin",
				"value": "one.devos.nautical.winterssummerfixes.WintersSummerFixes"
			}
		],
		"client": [
			{
				"adapter": "kotlin",
				"value": "one.devos.nautical.winterssummerfixes.client.WintersSummerFixesClient"
			}
		],
		"server": [
			{
				"adapter": "kotlin",
				"value": "one.devos.nautical.winterssummerfixes.server.WintersSummerFixesServer"
			}
		]
	},
	"mixins": [
		"winterssummerfixes.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}